# Public environment template — actual values live in .envrc.private (gitignored).
# Copy the variables below into .envrc.private and fill in your values.
source_env_if_exists .envrc.private

# ── Variables expected in .envrc.private ──────────────────────────────────────
# WhatsApp / Meta
#   APP_ID
#   BUSINESS_ACCOUNT_ID
#   GEAR_OFFER_FLOW_ID
#   WHATSAPP_PHONE_ID              (active phone — set to TEST or PROD value)
#   WHATSAPP_PHONE_ID_TEST
#   WHATSAPP_PHONE_ID_PROD
#   WHATSAPP_BUSINESS_ACCOUNT_ID
#   WHATSAPP_BUSINESS_ACCOUNT_ID_TEST
#   WHATSAPP_BUSINESS_ACCOUNT_ID_PROD
#   WHATSAPP_PHONE_NUMBER_TEST
#   WHATSAPP_PHONE_NUMBER_PROD
#   WHATSAPP_ACCESS_TOKEN
#   WHATSAPP_VERIFY_TOKEN
#
# App
#   ADMIN_WHATSAPP                 (admin phone for internal notifications)
#   KITETOGO_WHATSAPP              (public bot number, e.g. +5491173598312)
#   SECRET_KEY_BASE
#
# Database
#   DATABASE_URL
#   PROD_DATABASE_URL
#
# Stripe
#   STRIPE_API_KEY
#   STRIPE_PUBLIC
#
# LLM Providers
#   OPENROUTER_API_KEY
#   GEMINI_API_KEY
#   MISTRAL_API_KEY
#   GROQ_API_KEY
#   TOGETHER_API_KEY
#   CEREBRAS_API_KEY
#   HUGGINGFACE_API_KEY
#
# Audio transcription
#   ASSEMBLYAI_API_KEY
#
# Monitoring / Logging
#   AXIOM_TOKEN
#   AXIOM_DATASET
#   AXIOM_DATASET_HTTP
#   AXIOM_ORG_ID
#
# Infrastructure
#   COOLIFY_APP_ID
#   COOLIFY_API_KEY
#   NGROK_AUTHTOKEN
